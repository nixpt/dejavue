__pycache__/
*.pyc
*.pyo

# .dejavue/ split: track what should travel with the repo, ignore per-checkout state.
# Tracked (NOT in gitignore): timeline.jsonl, state.md, decisions.md, handoff.md, references/
# Ignored below: rebuildable indexes + per-checkout markers + locks
.dejavue/fts.db
.dejavue/*.tmp
.dejavue/.first-use
.dejavue/ingested.lock
.dejavue/.locks/

# Stray config not part of dejavue (flag to maintainer internal session)
seahorse-server.toml
